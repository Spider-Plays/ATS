# Database — use InsForge Postgres connection string:
#   npx @insforge/cli db connection-string
DATABASE_URL="postgresql://..."

# InsForge (server admin access for storage; never expose API key to frontend)
INSFORGE_URL="https://3ixy53ge.ap-southeast.insforge.app"
INSFORGE_API_KEY=""
INSFORGE_ANON_KEY=""

JWT_SECRET="generate-a-long-random-string-at-least-32-characters"
PORT=4000
CLIENT_ORIGIN="http://localhost:3000,https://stitch-ats.in,https://www.stitch-ats.in,https://stitch-ats.insforge.site,https://3ixy53ge.insforge.site"

# Resend — optional; InsForge can send auth emails when configured in dashboard
RESEND_API_KEY=""
EMAIL_FROM="Stitch ATS <onboarding@resend.dev>"
APP_NAME="Stitch ATS"

# Local fallback when INSFORGE_API_KEY is unset
RESUME_UPLOAD_DIR=""

# Bootstrap first admin (production)
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_NAME="Administrator"
