# Copy to .env — Neon pooled connection (same value as Render DATABASE_URL)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# One-time migration from InsForge Postgres:
#   $env:NEON_DATABASE_URL="postgresql://...@ep-xxx-pooler....neon.tech/neondb?sslmode=require"
#   npm run db:migrate-to-neon --prefix server

JWT_SECRET="generate-a-long-random-string-at-least-32-characters"
PORT=4000
CLIENT_ORIGIN="http://localhost:3000,https://stitch-ats.in,https://www.stitch-ats.in,https://ats.pages.dev"
# Optional: force email/login links to a specific URL (overrides CLIENT_ORIGIN resolution)
# APP_URL="https://stitch-ats.in"

# --- QA staging (local dev defaults here when server/.env.staging exists) ---
# 1. Copy Neon qa branch pooled URL (or Render stitch-ats-api-staging DATABASE_URL)
# 2. npm run env:qa   (with STAGING_DATABASE_URL set)
# 3. npm run dev      (loads server/.env.staging automatically)
# Production DB locally: npm run dev:prod

# DATABASE_URL=<Neon staging branch pooled URL>

# Email — Microsoft 365 (preferred) or Resend fallback
# IT team: use /api/integrations/m365 with X-Integration-Api-Key after setting M365_INTEGRATION_API_KEY
M365_TENANT_ID=""
M365_CLIENT_ID=""
M365_CLIENT_SECRET=""
M365_SENDER_EMAIL=""
M365_SENDER_DISPLAY_NAME="Stitch ATS"
M365_INTEGRATION_API_KEY=""

# Interview calendar (Microsoft 365)
# Requires Calendars.ReadWrite application permission on the Azure app (in addition to Mail.Send)
M365_CALENDAR_ENABLED="true"
M365_AUTO_TEAMS_MEETING="true"
M365_CALENDAR_ORGANIZER_EMAIL=""
M365_CALENDAR_TIMEZONE="Asia/Kolkata"

# Resend — optional fallback when M365 is not configured
RESEND_API_KEY=""
EMAIL_FROM="Stitch ATS <talentacquisition@stitch-ats.in>"
APP_NAME="Stitch ATS"

# Offers — annual CTC at or above this value requires executive approval after HR step
OFFER_EXEC_APPROVAL_THRESHOLD=2500000

# Resume uploads (local disk on Render; set a persistent path if your plan supports it)
RESUME_UPLOAD_DIR=""

# Bootstrap first admin (production)
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_NAME="Super Administrator"
ADMIN_ROLE="SUPER_ADMIN"
