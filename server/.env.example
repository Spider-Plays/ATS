# Copy to .env — MUST be your Neon URL (same as Render DATABASE_URL)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

JWT_SECRET="generate-a-long-random-string-at-least-32-characters"
PORT=4000
CLIENT_ORIGIN="http://localhost:3000,https://stitch-ats.in,https://www.stitch-ats.in"

# Email — Microsoft 365 (preferred) or Resend fallback
# IT team: use /api/integrations/m365 with X-Integration-Api-Key after setting M365_INTEGRATION_API_KEY
M365_TENANT_ID=""
M365_CLIENT_ID=""
M365_CLIENT_SECRET=""
M365_SENDER_EMAIL=""
M365_SENDER_DISPLAY_NAME="Stitch ATS"
M365_INTEGRATION_API_KEY=""

# Interview calendar (Microsoft 365)
# Requires Calendars.ReadWrite application permission on the Azure app (in addition to Mail.Send)
M365_CALENDAR_ENABLED="true"
M365_AUTO_TEAMS_MEETING="true"
M365_CALENDAR_ORGANIZER_EMAIL=""
M365_CALENDAR_TIMEZONE="Asia/Kolkata"

# Resend — optional fallback when M365 is not configured
RESEND_API_KEY=""
EMAIL_FROM="Stitch ATS <talentacquisition@stitch-ats.in>"
APP_NAME="Stitch ATS"

# Offers — annual CTC at or above this value requires executive approval after HR step
OFFER_EXEC_APPROVAL_THRESHOLD=2500000

# Resume uploads (local disk on Render; set a persistent path if your plan supports it)
RESUME_UPLOAD_DIR=""

# Bootstrap first admin (production)
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_NAME="Administrator"
