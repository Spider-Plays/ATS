# QA staging — copy to server/.env.staging (or run: npm run env:qa)
# Uses Neon qa branch + same email provider as production (M365 preferred).

DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

JWT_SECRET="generate-a-long-random-string-at-least-32-characters"
PORT=4000
CLIENT_ORIGIN="http://localhost:3000,https://qa.stitch-ats.in"
APP_URL="https://qa.stitch-ats.in"

# Email — copy M365_* (or RESEND_API_KEY) from Render stitch-ats-api production to staging
M365_TENANT_ID=""
M365_CLIENT_ID=""
M365_CLIENT_SECRET=""
M365_SENDER_EMAIL=""
M365_SENDER_DISPLAY_NAME="Stitch ATS (QA)"
M365_INTEGRATION_API_KEY=""

M365_CALENDAR_ENABLED="true"
M365_AUTO_TEAMS_MEETING="true"
M365_CALENDAR_ORGANIZER_EMAIL=""
M365_CALENDAR_TIMEZONE="Asia/Kolkata"

RESEND_API_KEY=""
EMAIL_FROM="Stitch ATS (QA) <talentacquisition@stitch-ats.in>"
APP_NAME="Stitch ATS (QA)"

OFFER_EXEC_APPROVAL_THRESHOLD=2500000
